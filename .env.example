# Copy to .env on the server. Replace every CHANGE_ME value before starting.

POSTGRES_DB=lottery
POSTGRES_USER=lottery
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

LOTTERY_DB_MIGRATIONS_ENABLED=true
LOTTERY_BCRYPT_COST=12
LOTTERY_ACCESS_TOKEN_TTL_SECONDS=900
LOTTERY_ACCESS_TOKEN_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_ACCESS_TOKEN_SECRET
LOTTERY_MOCK_PAYMENT_WEBHOOK_SECRET=CHANGE_ME_PAYMENT_WEBHOOK_HMAC_SECRET

LOTTERY_FRONTEND_BASE_URL=https://lottery.example.com
LOTTERY_BACKEND_BASE_URL=https://lottery.example.com/api/v1
LOTTERY_CORS_ALLOWED_ORIGINS=https://lottery.example.com
VITE_API_BASE_URL=/api/v1

LOTTERY_HOST_HTTP_PORT=8090
LOTTERY_LOG_MAX_SIZE=10m
LOTTERY_LOG_MAX_FILES=5
